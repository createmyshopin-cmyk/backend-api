# Required — platform tier (auto-inferred on Railway when unset)
PLATFORM_TIER=production

# Required — production CORS allowlist (auto-defaults to ADMIN_PANEL_URL or https://admin.creomine.com on Railway)
CORS_ORIGINS=https://admin.creomine.com
ADMIN_PANEL_URL=https://admin.creomine.com

NODE_ENV=production
PORT=5000

JWT_SECRET=
ADMIN_INVITE_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# NestJS server port
PORT=5000

# JSON Web Token secret key (min 32 characters)
JWT_SECRET=your-jwt-long-secret-key-goes-here

# Supabase database config
SUPABASE_URL=your-supabase-url-goes-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-goes-here

# Firebase service account credentials (needed for user auth & push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key-here\n-----END PRIVATE KEY-----\n"

# Agora App ID & Certificate (needed for generating secure RTC call tokens)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Razorpay — generate BOTH from Dashboard → API Keys (Test mode). See RAZORPAY_SETUP.md
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-24-char-secret-no-quotes

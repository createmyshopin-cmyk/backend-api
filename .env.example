# JWT — required for POST /api/auth/firebase-login and protected routes
JWT_SECRET=your-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# Supabase (voiceZAPI or your project) — enables live creators on GET /api/creators
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Flutter Realtime (anon key — safe with RLS read policy on creator_profiles)
# SUPABASE_ANON_KEY=your_anon_key

# Agora Voice Calling — https://docs.agora.io/en/voice-calling/overview/product-overview
# Tokens must be generated on the SERVER (never put App Certificate in Flutter).
#
# Option A (production): App ID + Primary App Certificate
#   1. https://console.agora.io → Project Management → your project
#   2. Copy App ID → AGORA_APP_ID
#   3. Security / Config → turn ON "Primary certificate" (Secured: APP ID + Token)
#   4. Click view/copy certificate → AGORA_APP_CERTIFICATE
#
# Option B (dev only, ~24h): Console → project → Generate temp token → AGORA_TOKEN
#   Keep AGORA_APP_ID set; leave AGORA_APP_CERTIFICATE empty.
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
# AGORA_TOKEN=

# Razorpay Credentials - https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

